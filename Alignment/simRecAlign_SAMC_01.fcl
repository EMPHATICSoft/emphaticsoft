#include "BeamGen.fcl"
#include "G4Gen.fcl"
#include "SSDDigitizer.fcl"
#include "MakeSSDClusters.fcl" 
#include "Services.fcl" 
#include "Geometry.fcl" 
#include "MakeTrackSegments.fcl" 
#include "MakeSingleTracks.fcl" 
#include "SingleTrackAlignmentV2.fcl" 

process_name: SimRecAlign

#
# This is an example fHICL file to drive a bean generation, Geant4 Simulation, generation of simulated SSD hits
# followed by SSD Cluster generation and ending with analyzer moduler, which align the SSD with respect to a 
# refrence frame defined by Station 0 and Station 4.
# That is, this art-based modules simulated the Alignment, in order to document. 
#   
# See tech note from Robert Chirco (Docdb 2302) and talk given by P.L. on March 31 (Docdb 2365) 
#
# In this example, we either 
#   - shift and rotate Station 1 w.o.r to this reference, and get back, possibly with small biases 
# these shifts (x or y), running the Millepede-II at the end of the job. 
# as below, not commented out, we randomly shift the stations 2, 3, 5, 6, and 7 and try 
# - unsucessfully - to reprocude reliably (> 99%), or better, these misalignments. 
#
# There is only one specific module in this FHICL file: The singletrackalignmentV2 module
# It is an anlyser module because it produce - optionally - a binary file, and/or a set of CSV 
# files (actually, the comas are blank space, as it is the default for R, but that is a detail..). 
# (A root Ntuple can easily be created from such files,  using the coding facility in ChatGPT.)
# See comments in the code for detail. 
# 
# This work flow needs the recent upgrade of the Geometry package, as we need to modify the geometry 
# and keep in memory two distinct instances of the Geometry (GeoDetMap) classes throughout the art Ptocess:
#  The first one is the "reference", the 2nd one is based on the simulated misalignments, or, when all is done, 
#  the "real" one.  More precisely, the best estimate of the real geometry. 
# One could call the first one the "not yet aligned one", used in the calculation the pulls, which are the
# distances from the track to the actual position of the SSD strip, generated in the G4EMPH package. 
# The generation of the simulated is done in the G4EMPH,  using this simulated misaligned geometry, 
# edited through the .../Geometry/ModAlign utility package.  
# 
# For most applications, such as in the final physics analysis, 
#   the reference and the real one are identical.          
#    
# Note : Since this is an example, I left an explicit path name for the reference GDML file, see below.. 
#
#  


services:
{
## This is need, to establish the map between electronic channels and detector channels 
  @table::standard_services
  # Load the service that manages root files for histograms.
# We do not need a standard art-root ouput file in this module, so, we do not need to modify the TFile service.  
#  TFileService: { fileName: "daq2root_%r_%s.root" closeFileFast: false }
  
   RandomNumberGenerator: {} #ART native random number generator
}

#Start each new event with an empty event.
source:
{
  module_type: EmptyEvent
  maxEvents: 25000  # it take typically a few tens of thousands of event to get to the micron or sub-micron level. 
  firstRun:  2998 # This is the number chosen for simulation, it does not correspond to a real run for Phase1c. 
  firstSubRun: 1

}

physics:
{
  producers:
  {
	generator: @local::standard_beamgen # existing code.. See below for specific 
	SSDSim: @local::standard_geant4  # we simulate the response of the detector. 
	SSDDigitizer: @local::standard_ssddigitizer # existing code, fixed such that art module labels and instance label do match. 
	clust: @local::standard_ssdclust # existing code. 
	tracksegments: @local::standard_maketracksegments  # Not needed in this context, left for eventual cross-checks. 
	makesingletracks: @local::standard_makesingletracks # same. 
  }
  analyzers:
  {
	singleTrackAlignment: @local::standard_singletrackalignmentV2  # This is the new module that produced the data for alignment.  
  }     

   simulate: [ generator, SSDSim, SSDDigitizer, clust]
# We can also do the tracksegment reconstruction. This is not necessary.     
#  simulate: [ generator, SSDSim, SSDDigitizer, clust, tracksegments]

  ana: [singleTrackAlignment]
  
  stream1: [  ]
#  stream1: [ dumper ]  # useful to check that we generate all the art data blocks, with correct labels.  

  trigger_paths: [ simulate ] # see above.. 

  end_paths: [ ana, stream1 ]
#  end_paths: [ stream1 ] # No output stream. 

}

outputs:
{
  dumper : {
      module_type              : FileDumperOutput
      wantProductFullClassName : true
      onlyIfPresent            : true
  }
#  out1:
#  {
#    module_type: RootOutput
#    fileName:    "emphmc_r%r_s%s.root" #default file name, can override from #command line with -o or --output
##    SelectEvents: [ simulate ]
#  }
}
#
# Now the relevant options. 
# 
services.GeometryService.GetGDMLFromRunHistory: false
services.GeometryService.GDMLFile: "/home/lebrun/EMPHATIC/emphaticsoft/ConstBase/Geometry/phase1c_Graphite.gdml"
services.GeometryService.MoveStationNumber: 999 # valid number are 1, 2, 3, 5, 6, 7 or 999, in which case we randomly shift all stations 
# except station 0 or 4. Specific options for station 4 phi angles also available 
# assumed mechanical tolerance for rand om moves.  
services.GeometryService.MoveStationByWidthX: 3.0
services.GeometryService.MoveStationByWidthY: 3.0
#
# same for phi rotation (around the Z axis.) 
services.GeometryService.RotateStationNumber: 999
services.GeometryService.RotateStationByWidthdPhi: 1.0 # in degrees.. 
#
services.GeometryService.RandomSeed: 45239 # such that the pseudo-random throw are reproducible, when debugging. 
# 
services.DetGeoMapService.UseAlign: false # We do not use the alignment date, instead, we use the modified geometry.  
physics.producers.SSDSim.G4AlgPSet.G4LastZPosition: 1800.
#physics.producers.SSDSim.PerformFOutStudy: true
physics.producers.generator.RandomSeed: 657389 # Again reproducibilty. To run on the grid, use a Unix Shell script (or Python) 
# to avoid running the same case on multiple nodes. 
# Usual stuff for the standard modules. 
physics.producers.generator.particleType: "proton"
physics.producers.generator.xyDistSource: "flatxy"
physics.producers.generator.xMax: 0.3 # cm ! 
physics.producers.generator.yMax: 0.3 # cm ! 
physics.producers.generator.Xmin: -0.3 # cm ! 
physics.producers.generator.Ymin: -0.3 # cm ! 
physics.producers.SSDDigitizer.FillAnaTree: false
physics.producers.SSDDigitizer.SkipChargeSharing: true
physics.producers.clust.SSDRawLabel: "SSDDigitizer"
physics.producers.clust.CheckDQ : false
physics.producers.clust.fCVSDebug : true
physics.producers.SSDDigitizer.G4Label: "SSDSim"
physics.producers.tracksegments.FillRootTree: false # for now.. Save a few CPU cycles..  
#
# Now comes our options and cuts, for the module of interest. Which could also work on real data!. 
#
#
physics.analyzers.singleTrackAlignment.Use123: true  # Since this is simulation exercise, we use all the data. No preselection on events number. 
physics.analyzers.singleTrackAlignment.Use456: true
physics.analyzers.singleTrackAlignment.Use7890: true
physics.analyzers.singleTrackAlignment.EffectiveMagnetKick: -0.55e-3 # This number has been obtained by looking at simulation
# tracing through the magnet.  It has been re-adjusted, with the best magnetic field map.  
physics.analyzers.singleTrackAlignment.DoSelectionStudies: true  # for making sure we get all the cluster we need. 
physics.analyzers.singleTrackAlignment.LineSegLabel: tracksegments  # could have been hardcoded. 
physics.analyzers.singleTrackAlignment.TrackSegLabel: tracksegments
physics.analyzers.singleTrackAlignment.SkipUW: false
physics.analyzers.singleTrackAlignment.RandomizePulls: false # see C++ code, the idea is to simulated additional noise, to make 
# the pulls more Gaussian distributed.  Not needed.. 
physics.analyzers.singleTrackAlignment.RunPede: false  # In this example, we don't bother generating the Millipede input binary file. 
physics.analyzers.singleTrackAlignment.ModeRunPede: 0 # Irrelevant in this case. 
physics.analyzers.singleTrackAlignment.GSLStudies: true # We do simple fits to to get the station rotation angles. 
physics.analyzers.singleTrackAlignment.TokenCSV: "Mag11GraphiteLargeProtonlAllMovesDR10" # for book-keeping.  
# The CSV file names are based on this token.
#
