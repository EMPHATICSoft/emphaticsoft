#include "BeamGen.fcl"
#include "G4Gen.fcl"
#include "SSDDigitizer.fcl"
#include "MakeSSDClusters.fcl" 
#include "Services.fcl" 
#include "Geometry.fcl" 
#include "MakeTrackSegments.fcl" 
#include "MakeSingleTracks.fcl" 
#include "SingleTrackAlignmentV2.fcl" 

process_name: DataRecAlign

#
# This is an example fHICL file to drive the reading of a "Prod6.x", art root file, 
# followed by SSD Cluster generation and ending with analyzer moduler, which align the SSD with respect to a 
# refrence frame defined by Station 0 and Station 4.
# That is, this art-based modules simulated the Alignment, in order to document. 
#   
# See tech note from Robert Chirco (Docdb 2302) and talk given by P.L. on March 31 (Docdb 2365) 
#
# In this example, we either 
#   - shift and rotate Station 1 w.o.r to this reference, and get back, possibly with small biases 
# these shifts (x or y), running the Millepede-II at the end of the job. 
# as below, not commented out, we randomly shift the stations 2, 3, 5, 6, and 7 and try 
# - unsucessfully - to reprocude reliably (> 99%), or better, these misalignments. 
#
# There is only one specific module in this FHICL file: The singletrackalignmentV2 module
# It is an anlyser module because it produce - optionally - a binary file, and/or a set of CSV 
# files (actually, the comas are blank space, as it is the default for R, but that is a detail..). 
# (A root Ntuple can easily be created from such files,  using the coding facility in ChatGPT.)
# See comments in the code for detail. 
# 
# This work flow needs the recent upgrade of the Geometry package, as we need to modify the geometry 
# and keep in memory two distinct instances of the Geometry (GeoDetMap) classes throughout the art Ptocess:
#  The first one is the "reference", the 2nd one is based on the simulated misalignments, or, when all is done, 
#  the "real" one.  More precisely, the best estimate of the real geometry. 
# One could call the first one the "not yet aligned one", used in the calculation the pulls, which are the
# distances from the track to the actual position of the SSD strip, generated in the G4EMPH package. 
# The generation of the simulated is done in the G4EMPH,  using this simulated misaligned geometry, 
# edited through the .../Geometry/ModAlign utility package.  
# 
# For most applications, such as in the final physics analysis, 
#   the reference and the real one are identical.          
#    
# Note : Since this is an example, I left an explicit path name for the reference GDML file, see below.. 
#
#  


services:
{
## This is need, to establish the map between electronic channels and detector channels 
  @table::standard_services
  # Load the service that manages root files for histograms.
# We do not need a standard art-root ouput file in this module, so, we do not need to modify the TFile service.  
#  TFileService: { fileName: "daq2root_%r_%s.root" closeFileFast: false }
  
   RandomNumberGenerator: {} #ART native random number generator
}

#Start each new event with an empty event.
source:
{

  module_type: RootInput
  maxEvents: -1

}

physics:
{
  producers:
  {
	clust: @local::standard_ssdclust # existing code. 
	tracksegments: @local::standard_maketracksegments  # Not needed in this context, left for eventual cross-checks. 
	makesingletracks: @local::standard_makesingletracks # same. 
  }
  analyzers:
  {
	singleTrackAlignment: @local::standard_singletrackalignmentV2  # This is the new module that produced the data for alignment.  
  }     

   simulate: [ generator, SSDSim, SSDDigitizer, clust]
# We can also do the tracksegment reconstruction. This is not necessary.     
#  simulate: [ generator, SSDSim, SSDDigitizer, clust, tracksegments]

  ana: [singleTrackAlignment]
  
  stream1: [  ]
#  stream1: [ dumper ]  # useful to check that we generate all the art data blocks, with correct labels.  

  trigger_paths: [ simulate ] # see above.. 

  end_paths: [ ana, stream1 ]
#  end_paths: [ stream1 ] # No output stream. 

}

outputs:
{
  dumper : {
      module_type              : FileDumperOutput
      wantProductFullClassName : true
      onlyIfPresent            : true
  }
#  out1:
#  {
#    module_type: RootOutput
#    fileName:    "emphmc_r%r_s%s.root" #default file name, can override from #command line with -o or --output
##    SelectEvents: [ simulate ]
#  }
}
#
# Now the relevant options. 
# 
services.GeometryService.GetGDMLFromRunHistory: false
services.GeometryService.GDMLFile: "/home/lebrun/EMPHATIC/emphaticsoft/ConstBase/Geometry/phase1c_Empty.gdml"
services.DetGeoMapService.UseAlign: false
physics.producers.clust.CheckDQ : false
physics.producers.clust.fCVSDebug : true 
#
physics.analyzers.singleTrackAlignment.Use123: true
physics.analyzers.singleTrackAlignment.Use456: false
physics.analyzers.singleTrackAlignment.Use7890: false
physics.analyzers.singleTrackAlignment.EffectiveMagnetKick: -0.55e-3
physics.analyzers.singleTrackAlignment.DoSelectionStudies: true
physics.analyzers.singleTrackAlignment.SkipUW: false
physics.analyzers.singleTrackAlignment.RandomizePulls: false
physics.analyzers.singleTrackAlignment.RunPede: false
physics.analyzers.singleTrackAlignment.ModeRunPede: 0
physics.analyzers.singleTrackAlignment.GSLStudies: true
physics.analyzers.singleTrackAlignment.TokenCSV: "Mag11Graphite"
#
