BEGIN_PROLOG

standard_arichdigitizer:
{    
  module_type: 	  ARICHDigitizer
  G4Label:	  "geantgen"
  IncludeNoise:   true  	# bool to evaluate the dark hits
  FillTree:    	  false
  DarkMapFile:	 ""
  XTalkProb: 	  0.07  #value from https://arxiv.org/pdf/1506.04302
  SigTimeLo:	 -290   #values from data phase1c
  SigTimeHi: 	 -260   #values from data phase1c
}

END_PROLOG
